# --- Required ---
GEMINI_API_KEY=your_gemini_api_key_here


# --- Optional overrides (defaults shown) ---
ENVIRONMENT=development
CORS_ORIGINS=*
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.3
CATALOG_SOURCE_URL=https://tcp-us-prod-rnd.shl.com/voiceRater/shl-ai-hiring/shl_product_catalog.json
CATALOG_CACHE_PATH=database/catalog.json
FAISS_INDEX_PATH=database/faiss.index
EMBEDDINGS_META_PATH=database/embeddings.pkl
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
MAX_TURNS=8
REQUEST_TIMEOUT_SECONDS=28
DEFAULT_TOP_K=8

# --- Auth / Database ---
# Local dev default (SQLite file). For production (Render, etc.) use a
# managed Postgres URL instead, e.g.:
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./database/app.db
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
